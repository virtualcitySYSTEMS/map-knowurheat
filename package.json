{
  "name": "@vcmap/knowurheat",
  "version": "1.1.1",
  "description": "Plugin to calculate rentability of Heat Pumps",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepublishOnly": "vcmplugin build",
    "build": "vcmplugin build",
    "bundle": "vcmplugin bundle",
    "start": "vcmplugin serve",
    "preview": "vcmplugin preview",
    "buildStagingApp": "vcmplugin buildStagingApp",
    "lint:js": "eslint . --ext .vue,.js,.cjs,.mjs,.ts,.cts,.mts",
    "lint:prettier": "prettier --check .",
    "lint": "npm run lint:js && npm run lint:prettier",
    "format": "prettier --write --list-different . && npm run lint:js -- --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "ensure-types": "vcmplugin ensure-types"
  },
  "author": "pwuerstle<pwuerstle@vc.systems>",
  "license": "MIT",
  "keywords": [
    "vcmap",
    "plugin"
  ],
  "files": [
    "src/",
    "dist/",
    "plugin-assets/",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "dist/index.js",
    "./dist": "./dist/index.js"
  },
  "eslintIgnore": [
    "node_modules",
    "dist",
    "plugin-assets"
  ],
  "prettier": "@vcsuite/eslint-config/prettier.js",
  "peerDependencies": {
    "@vcmap-cesium/engine": "^11.0.2",
    "@vcmap/core": "^6.0.6",
    "@vcmap/ui": "^6.0.10",
    "ol": "^10.3.1",
    "vue": "~3.4.38",
    "vuetify": "^3.7.3"
  },
  "overrides": {
    "dompurify": "^3.2.4",
    "esbuild": "^0.25.0",
    "canvg": "4.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@vcmap/plugin-cli": "^4.2.0",
    "@vcsuite/eslint-config": "^3.0.8",
    "@vitest/coverage-v8": "^4.1.5",
    "jest-canvas-mock": "^2.5.2",
    "jsdom": "^24.1.1",
    "resize-observer-polyfill": "^1.5.1",
    "typescript": "~5.6.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.1.10"
  },
  "mapVersion": "^6.0",
  "dependencies": {
    "@vcsuite/logger": "^1.0.1",
    "@vcsuite/parsers": "^2.0.0",
    "apexcharts": "^3.54.1",
    "fast-deep-equal": "^3.1.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "uuid": "^14.0.0",
    "vue3-apexcharts": "~1.7.0"
  }
}
